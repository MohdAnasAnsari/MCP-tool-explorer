# ═══════════════════════════════════════════════════════════════════════════════
# MCP Tool Explorer — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env with real credentials to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Your PostgreSQL Database (optional — leave blank to disable DB tools) ────
# Connect any PostgreSQL database you own. Read-only access is enforced.
DB_HOST=your_postgres_host          # e.g.  192.168.1.10  or  db.example.com
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_db_username
DB_PASSWORD=your_db_password

# ─── AI / LLM — only ONE key is needed ───────────────────────────────────────
# Option A: Groq — FREE, no credit card required
#   Get key: https://console.groq.com → API Keys → Create Key
GROQ_API_KEY=

# Option B: OpenAI — requires billing
#   Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── Internal app database (auto-created by Docker, just set a password) ──────
APP_DB_PASSWORD=choose_a_strong_password_here

# ─── Auth service settings ────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars
JWT_EXPIRE_HOURS=24

# Default admin account created on first startup
ADMIN_EMAIL=admin@yourcompany.com
ADMIN_PASSWORD=ChangeThisPassword@123
ADMIN_NAME=System Admin

# ─── Internal URLs (set automatically by docker-compose — do not change) ──────
MCP_SERVER_URL=http://server:8000/sse
AUTH_SERVICE_URL=http://auth:8001
